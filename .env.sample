# Application
BASE_URL=https://mail.mcp.mitigate.dev
RACK_ENV=development
PORT=3000

# Security — used for all JWE tokens (client_id, access, refresh)
# Generate with: ruby -e "require 'base64','securerandom'; puts Base64.strict_encode64(SecureRandom.bytes(32))"
ENCRYPTION_KEY=replace-with-base64-encoded-32-bytes

# AWS S3 (for attachment storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=mail_mcp-attachments
