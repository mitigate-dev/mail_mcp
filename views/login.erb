<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mail MCP — Connect</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f5f5f7;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 1rem;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 420px;
    }
    h1 { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.25rem; color: #1d1d1f; }
    .subtitle { font-size: 0.9rem; color: #6e6e73; margin-bottom: 0.5rem; }
    .server-info {
      font-size: 0.8rem; color: #6e6e73;
      background: #f5f5f7; border-radius: 6px;
      padding: 0.5rem 0.75rem; margin-bottom: 1.5rem;
    }
    .server-info span { font-weight: 600; color: #1d1d1f; }
    .error {
      background: #fff2f2;
      border: 1px solid #ffcdd2;
      color: #b71c1c;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      margin-bottom: 1.25rem;
    }
    label { display: block; font-size: 0.8rem; font-weight: 600; color: #1d1d1f; margin-bottom: 0.3rem; margin-top: 1rem; }
    input[type="text"], input[type="password"] {
      width: 100%; border: 1px solid #d2d2d7; border-radius: 8px;
      padding: 0.6rem 0.75rem; font-size: 0.95rem; color: #1d1d1f;
      transition: border-color 0.15s;
    }
    input:focus { outline: none; border-color: #0071e3; box-shadow: 0 0 0 3px rgba(0,113,227,0.15); }
    .section-title {
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; color: #6e6e73; margin-top: 1.5rem; margin-bottom: 0.25rem;
    }
    .checkbox-row {
      display: flex; align-items: center; gap: 0.5rem;
      margin-top: 1rem; margin-bottom: 0.25rem;
    }
    .checkbox-row input[type="checkbox"] { width: 1rem; height: 1rem; cursor: pointer; }
    .checkbox-row label { margin: 0; font-size: 0.875rem; font-weight: 400; color: #1d1d1f; cursor: pointer; }
    button[type="submit"] {
      width: 100%; margin-top: 1.75rem;
      background: #0071e3; color: #fff; border: none;
      border-radius: 8px; padding: 0.75rem; font-size: 1rem; font-weight: 600;
      cursor: pointer; transition: background 0.15s;
    }
    button[type="submit"]:hover { background: #0077ed; }
  </style>
</head>
<body>
<div class="card">
  <h1>Mail MCP</h1>
  <p class="subtitle">Connect your email account to continue</p>
  <div class="server-info">
    IMAP <span><%= @params[:imap_host] %></span> &nbsp;·&nbsp;
    SMTP <span><%= @params[:smtp_host] %></span>
  </div>

  <% if @params[:error] %>
    <div class="error"><%= @params[:error] %></div>
  <% end %>

  <form method="POST" action="/oauth/authorize">
    <input type="hidden" name="client_id"             value="<%= @params[:client_id] %>">
    <input type="hidden" name="redirect_uri"          value="<%= @params[:redirect_uri] %>">
    <input type="hidden" name="state"                 value="<%= @params[:state] %>">
    <input type="hidden" name="code_challenge"        value="<%= @params[:code_challenge] %>">
    <input type="hidden" name="code_challenge_method" value="<%= @params[:code_challenge_method] %>">

    <div class="section-title">IMAP (Incoming)</div>

    <label for="imap_username">IMAP Username</label>
    <input type="text" id="imap_username" name="imap_username"
           placeholder="you@example.com" autocomplete="username" required>

    <label for="imap_password">IMAP Password</label>
    <input type="password" id="imap_password" name="imap_password"
           placeholder="••••••••" autocomplete="current-password" required>

    <div class="checkbox-row">
      <input type="checkbox" id="use_same" name="use_same_credentials" value="1" checked>
      <label for="use_same">Use the same username and password for SMTP</label>
    </div>

    <div id="smtp-fields" style="display:none">
      <div class="section-title">SMTP (Outgoing)</div>

      <label for="smtp_username">SMTP Username</label>
      <input type="text" id="smtp_username" name="smtp_username"
             placeholder="you@example.com" autocomplete="username">

      <label for="smtp_password">SMTP Password</label>
      <input type="password" id="smtp_password" name="smtp_password"
             placeholder="••••••••" autocomplete="current-password">
    </div>

    <button type="submit">Connect</button>
  </form>
</div>

<script>
  const checkbox = document.getElementById('use_same');
  const smtpFields = document.getElementById('smtp-fields');
  function toggle() { smtpFields.style.display = checkbox.checked ? 'none' : 'block'; }
  checkbox.addEventListener('change', toggle);
  toggle();
</script>
</body>
</html>
